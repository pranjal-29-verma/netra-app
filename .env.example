# ============================================================
# Netra Chatbot — Backend Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/netra_db

# ------------------------------------------------------------
# JWT / Auth
# ------------------------------------------------------------
# Generate: openssl rand -hex 32
SECRET_KEY=your_secure_random_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------
# Google OAuth
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ------------------------------------------------------------
# Supabase Storage
# ------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=documents

# ------------------------------------------------------------
# Voyage AI (embeddings)
# ------------------------------------------------------------
VOYAGE_API_KEY=your_voyage_api_key

# ------------------------------------------------------------
# LLM Provider Keys
# Set whichever key matches your chosen LLM_MODEL
# Overridden at runtime when admin activates a custom model via UI
# ------------------------------------------------------------
LLM_MODEL=gemini/gemini-2.0-flash
GEMINI_API_KEY=your_gemini_api_key
ANTHROPIC_API_KEY=                  # required for claude-* models
OPENAI_API_KEY=                     # required for gpt-* models
MISTRAL_API_KEY=                    # required for mistral-* models

# Fernet key for encrypting LLM API keys stored in DB
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LLM_ENCRYPTION_KEY=your_fernet_key_here

# Max concurrent outbound LLM calls (prevents hammering the provider)
LLM_MAX_CONCURRENT=5

# ------------------------------------------------------------
# Token Quota
# ------------------------------------------------------------
DEFAULT_DAILY_TOKEN_QUOTA=100000

# ------------------------------------------------------------
# Netra Notify (internal email microservice)
# Set NOTIFY_ENABLED=true once netra-notify is running
# ------------------------------------------------------------
NOTIFY_BASE_URL=http://localhost:8001
NOTIFY_API_KEY=change-me-in-production
NOTIFY_ENABLED=false

# ------------------------------------------------------------
# API Rate Limits (slowapi format: "N/second|minute|hour")
# ------------------------------------------------------------
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/minute
RATE_LIMIT_GOOGLE=5/minute
RATE_LIMIT_REFRESH=10/minute
RATE_LIMIT_CHAT=20/minute

# ------------------------------------------------------------
# CORS
# ------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:5174"]

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
ENVIRONMENT=development
